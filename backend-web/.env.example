# 环境配置
ENVIRONMENT=development

# 日志配置
LOG_LEVEL=INFO

# 数据库配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=xianyu_auto_reply

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# Backend-Web服务配置
BACKEND_WEB_PORT=8089

# JWT配置
JWT_SECRET_KEY=your-secret-key-change-me-to-a-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# CORS配置（* 表示允许所有来源，生产环境建议指定具体域名）
CORS_ORIGINS=*

# 服务间通信URL
WEBSOCKET_SERVICE_URL=http://localhost:8090
SCHEDULER_SERVICE_URL=http://localhost:8091

# 静态文件目录（共享）
STATIC_DIR=static

# 前端公网访问地址（用于生成前端页面分享链接）
FRONTEND_PUBLIC_URL=http://localhost:9000

# Backend-Web服务的公网访问地址（用于生成文件URL）
BACKEND_WEB_PUBLIC_URL=http://localhost:8089
AUTO_START_CRAWL_JOBS=false

# TradingHub RiskManager order callback adapter
TRADINGHUB_ORDER_CALLBACK_URL=http://localhost:3000/api/external/order-callback
EXTERNAL_ORDER_CALLBACK_SECRET=
PRODUCT_SLUG=riskmanager

# TradingHub admin control API token. Must match Tradinghub-Web XIANYU_SERVICE_INTERNAL_TOKEN.
XIANYU_SERVICE_INTERNAL_TOKEN=
XIANYU_BACKEND_BASE_URL=http://127.0.0.1:8089
XIANYU_BACKEND_TOKEN=
XIANYU_BACKEND_QR_TIMEOUT_SECONDS=90
XIANYU_ORDER_BRIDGE_INTERVAL_SECONDS=10
